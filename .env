# NOTA: NUNCA COMPARTAS ESTE ARCHIVO.
# Rellena los valores a medida que vayas creando las cuentas.

# --- 1. WhatsApp Cloud API ---
# El token que sirve para validar tu servidor cuando Meta lo intente conectar
WHATSAPP_VERIFY_TOKEN=mi_token_botagenda_2026
# El token de tu app de Facebook para poder ENVIAR mensajes
WHATSAPP_TOKEN=
# Tu número de teléfono o ID del número que te da Meta para testeo
WHATSAPP_NUMBER_ID=

# --- 2. Google Gemini AI ---
GEMINI_API_KEY=

# --- 3. Google Calendar ---
# Para Google Calendar, el archivo principal será credentials.json que descargarás.
# Podrías poner también un ID de calendario específico (si no es el primario)
CALENDAR_ID=primary
